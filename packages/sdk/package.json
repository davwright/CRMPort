{
  "name": "@crmport/sdk",
  "version": "0.2.0",
  "description": "Client SDK for CRMPort - connect browser extensions to the local CRMPort server",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./installer": {
      "import": {
        "types": "./dist/installer.d.mts",
        "default": "./dist/installer.mjs"
      },
      "require": {
        "types": "./dist/installer.d.ts",
        "default": "./dist/installer.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  }
}
