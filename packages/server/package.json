{
  "name": "@crmport/server",
  "version": "0.1.1",
  "private": true,
  "description": "CRMPort local server",
  "main": "dist/main.js",
  "scripts": {
    "bump": "node -e \"const f='package.json';const p=JSON.parse(require('fs').readFileSync(f));const v=p.version.split('.');v[2]=+v[2]+1;p.version=v.join('.');require('fs').writeFileSync(f,JSON.stringify(p,null,2)+'\\n');console.log('v'+p.version)\"",
    "prebuild": "npm run bump",
    "build": "tsc",
    "predev": "npm run bump",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "keygen": "tsx src/tools/keygen.ts"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "chokidar": "^4.0.3",
    "fastify": "^5.2.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.2",
    "simple-git": "^3.27.0",
    "systray2": "^2.1.4",
    "semver": "^7.7.1"
  },
  "devDependencies": {
    "@types/auto-launch": "^5.0.5",
    "@types/semver": "^7.5.8",
    "@types/node": "^22.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
